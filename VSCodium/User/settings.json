    "editor.tokenColorCustomizations": {
        "textMateRules": [
            {
                "name": "unison punctuation",
                "scope": "punctuation.definition.delayed.unison,punctuation.definition.list.begin.unison,punctuation.definition.list.end.unison,punctuation.definition.ability.begin.unison,punctuation.definition.ability.end.unison,punctuation.operator.assignment.as.unison,punctuation.separator.pipe.unison,punctuation.separator.delimiter.unison,punctuation.definition.hash.unison",
                "settings": {
                    "foreground": "#ff7373"
                }
            },
            {
                "name": "haskell variable generic-type",
                "scope": "variable.other.generic-type.haskell",
                "settings": {
                    "foreground": "#a6e2ff"
                }
            },
            {
                "name": "haskell storage type",
                "scope": "storage.type.haskell",
                "settings": {
                    "foreground": "#c3ffeb"
                }
            },
            {
                "name": "support.variable.magic.python",
                "scope": "support.variable.magic.python",
                "settings": {
                    "foreground": "#ff7373"
                }
            },
            {
                "name": "punctuation.separator.parameters.python",
                "scope": "punctuation.separator.period.python,punctuation.separator.element.python,punctuation.parenthesis.begin.python,punctuation.parenthesis.end.python",
                "settings": {
                    "foreground": "#d4d4d4"
                }
            },
            {
                "name": "variable.parameter.function.language.special.self.python",
                "scope": "variable.parameter.function.language.special.self.python",
                "settings": {
                    "foreground": "#aaee57"
                }
            },
            {
                "name": "python parameter",
                "scope": "variable.parameter.function.language.python,variable.parameter.function.python,function.parameter,variable.parameter.function.js",
                "settings": {
                    "foreground": "#c3ffeb"
                }
            },
            {
                "name": "rust",
                "scope": "storage.modifier.lifetime.rust,keyword.operator.misc.rust",
                "settings": {
                    "foreground": "#d4d4d4"
                }
            },
            {
                "name": "rust std",
                "scope": "support.function.std.rust",
                "settings": {
                    "foreground": "#c89aff"
                }
            },
            {
                "name": "rust lifetime and language",
                "scope": "entity.name.lifetime.rust,variable.language.rust",
                "settings": {
                    "foreground": "#aaee57"
                }
            },
            {
                "name": "operators purple",
                "scope": "keyword.operator.logical,keyword.operator.bitwise,keyword.operator.channel,keyword.operator.assignment.compound.js,keyword.operator.assignment.compound.ts,keyword.operator.assignment,keyword.operator.arithmetic,keyword.operator.comparison,keyword.operator.decrement,keyword.operator.increment,keyword.operator.relational,keyword.operator.logical.php,keyword.operator.bitwise.php,keyword.operator.arithmetic.php,keyword.operator.comparison.php,keyword.operator.logical.python,keyword.operator.css,keyword.operator.scss,keyword.operator.less",
                "settings": {
                    "foreground": "#c27aff"
                }
            },
            {
                "name": "operators blue",
                "scope": "keyword.operator.expression.instanceof,keyword.operator.new,keyword.operator.ternary,keyword.operator.optional,keyword.operator.expression.keyof,keyword.operator.delete,keyword.operator.expression.delete,keyword.operator.expression.in,keyword.operator.expression.of,keyword.operator.expression.instanceof,keyword.operator.expression.typeof,keyword.operator.expression.void,keyword.operator.module,keyword.operator.quantifier.regexp,keyword.operator.sizeof.c,keyword.operator.sizeof.cpp,keyword.operator.regexp.php,keyword.operator.heredoc.php,keyword.operator.nowdoc.php",
                "settings": {
                    "foreground": "#a6e2ff"
                }
            },
            {
                "name": "strings",
                "scope": "string,markup.inline.raw.markdown,markup.inline.raw.string.markdown,keyword.other.template.begin,keyword.other.template.end,keyword.other.substitution.begin,keyword.other.substitution.end",
                "settings": {
